local function clean()
    for _,v in ipairs(spawned) do
        pcall(function()
            if v and v.Parent then v:Destroy() end
        end)
    end
    spawned = {}
    for _,v in ipairs(sounds) do
        pcall(function()
            v:Stop()
            v:Destroy()
        end)
    end
    sounds = {}
end

local function spawnElmo(fly)
    if #spawned >= MAX_PARTS then
        local old = table.remove(spawned, 1)
        pcall(function()
            if old and old.Parent then old:Destroy() end
        end)
    end
    
    local char = localPlayer and localPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local p = Instance.new("Part")
    p.Size = Vector3.new(math.random(3,8), math.random(3,8), math.random(3,8)) 
    p.Anchored = true
    p.CanCollide = false
    p.Material = Enum.Material.Neon
    p.Color = Color3.fromRGB(255, math.random(0,40), 0)
    p.Transparency = 0
    
    local ang = math.rad(math.random(0,360))
    p.Position = root.Position + Vector3.new(
        math.cos(ang)*math.random(10,80),
        math.random(-10,35),
        math.sin(ang)*math.random(10,80)
    )
    
    local m = Instance.new("SpecialMesh", p)
    m.MeshType = Enum.MeshType.FileMesh
    m.MeshId = "rbxassetid://8051563844"
    m.Scale = Vector3.new(math.random(3,6), math.random(3,6), math.random(3,6)) 
    
    local bill = Instance.new("BillboardGui", p)
    bill.Size = UDim2.new(0, 300, 0, 100) 
    bill.ExtentsOffset = Vector3.new(0, 4, 0)
    bill.Adornee = p
    bill.AlwaysOnTop = true
    
    local l = Instance.new("TextLabel", bill)
    l.Size = UDim2.new(1,0,1,0)
    l.BackgroundTransparency = 1
    l.Text = billboardTexts[math.random(1, #billboardTexts)]
    l.TextColor3 = Color3.fromRGB(255, 0, 0) 
    l.Font = Enum.Font.GothamBold
    l.TextScaled = true 
    
    p.Parent = workspace
    table.insert(spawned, p)
    
    if fly then
        task.spawn(function()
            for f=1,120 do 
                local c = localPlayer and localPlayer.Character
                if c and c:FindFirstChild("HumanoidRootPart") and p and p.Parent then
                    p.CFrame = p.CFrame:Lerp(CFrame.new(c.HumanoidRootPart.Position), 0.25 + math.random()*0.15)
                    RunService.RenderStepped:Wait()
                else 
                    break 
                end
            end
        end)
    end
end

