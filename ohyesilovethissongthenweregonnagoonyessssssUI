local function forceRedMapFog()
    Lighting.FogColor = Color3.new(1, 0, 0) 
    Lighting.FogStart = 0
    Lighting.FogEnd = 35 

    local atmosphere = Lighting:FindFirstChildOfClass("Atmosphere")
    if not atmosphere then
        atmosphere = Instance.new("Atmosphere")
        atmosphere.Parent = Lighting
    end
    atmosphere.Density = 0.85 
    atmosphere.Color = Color3.new(1, 0, 0)
    atmosphere.Decay = Color3.new(0.5, 0, 0)
    atmosphere.Glare = 0
    atmosphere.Haze = 5
end

